# Use the SAME Supabase project as the TourBid app (same URL and anon key).
# This way the website and app share: users, services (tours), bookings, etc.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Book-in-app link base URL (e.g. your main app or PWA)
VITE_APP_URL=https://your-app-url.com

# Optional: for /api/signup (serverless) to bypass email rate limit — set in Vercel → Project → Settings → Environment Variables
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
