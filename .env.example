# Use the SAME Supabase project as the GeorgiaTours app (same URL and anon key).
# This way the website and app share: users, services (tours), bookings, etc.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Book-in-app link base URL (e.g. your main app or PWA)
VITE_APP_URL=https://your-app-url.com
